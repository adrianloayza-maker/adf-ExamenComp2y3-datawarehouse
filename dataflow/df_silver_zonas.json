{
	"name": "df_silver_zonas",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_tbl_zonas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_zonas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_zona as string,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as string,",
				"          nivel_riesgo as string,",
				"          acceso_carretero as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_zona as string,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as string,",
				"          nivel_riesgo as string,",
				"          acceso_carretero as string",
				"     ),",
				"     partitionFileNames:['tbl_zonas.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}