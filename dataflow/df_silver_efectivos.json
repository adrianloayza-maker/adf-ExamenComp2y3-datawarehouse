{
	"name": "df_silver_efectivos",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_tbl_efectivos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_efectivo as string,",
				"          id_especialidad as string,",
				"          id_unidad_actual as string,",
				"          id_rango_actual as string,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as string,",
				"          estado as string,",
				"          salario_mensual as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(genero = iif(\r",
				"    upper(trim(genero)) == 'M' ||\r",
				"    upper(trim(genero)) == 'MASC' ||\r",
				"    upper(trim(genero)) == 'MASC.' ||\r",
				"    upper(trim(genero)) == 'H' ||\r",
				"    upper(trim(genero)) == 'HOMBRE' ||\r",
				"    upper(trim(genero)) == 'MASCULINO',\r",
				"\r",
				"    'MASCULINO',\r",
				"\r",
				"    iif(\r",
				"        upper(trim(genero)) == 'F' ||\r",
				"        upper(trim(genero)) == 'FEM' ||\r",
				"        upper(trim(genero)) == 'FEM.' ||\r",
				"        upper(trim(genero)) == 'MUJER' ||\r",
				"        upper(trim(genero)) == 'FEMENINO',\r",
				"\r",
				"        'FEMENINO',\r",
				"\r",
				"        'SIN DATO'\r",
				"    )\r",
				"),",
				"          departamento_origen = iif(\r",
				"    upper(trim(departamento_origen)) == 'LP' ||\r",
				"    upper(trim(departamento_origen)) == 'L.P.' ||\r",
				"    upper(trim(departamento_origen)) == 'LAPAZ' ||\r",
				"    upper(trim(departamento_origen)) == 'LA PAZ',\r",
				"\r",
				"    'LA PAZ',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'CBBA' ||\r",
				"    upper(trim(departamento_origen)) == 'CBBA.' ||\r",
				"    upper(trim(departamento_origen)) == 'COCHABAMBA',\r",
				"\r",
				"    'COCHABAMBA',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'SC' ||\r",
				"    upper(trim(departamento_origen)) == 'SCZ' ||\r",
				"    upper(trim(departamento_origen)) == 'STA CRUZ' ||\r",
				"    upper(trim(departamento_origen)) == 'SANTA CRUZ',\r",
				"\r",
				"    'SANTA CRUZ',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'OR' ||\r",
				"    upper(trim(departamento_origen)) == 'ORURO',\r",
				"\r",
				"    'ORURO',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'PT' ||\r",
				"    upper(trim(departamento_origen)) == 'POTOSI',\r",
				"\r",
				"    'POTOSI',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'TJ' ||\r",
				"    upper(trim(departamento_origen)) == 'TARIJA',\r",
				"\r",
				"    'TARIJA',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'BN' ||\r",
				"    upper(trim(departamento_origen)) == 'BENI',\r",
				"\r",
				"    'BENI',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'PD' ||\r",
				"    upper(trim(departamento_origen)) == 'PANDO',\r",
				"\r",
				"    'PANDO',\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento_origen)) == 'CH' ||\r",
				"    upper(trim(departamento_origen)) == 'CHUQUISACA',\r",
				"\r",
				"    'CHUQUISACA',\r",
				"\r",
				"    'SIN DATO'\r",
				"))))))))),",
				"          estado = iif(\r",
				"    upper(trim(estado)) == 'ACTIVO' ||\r",
				"    upper(trim(estado)) == 'ACT' ||\r",
				"    upper(trim(estado)) == 'ACT.' ||\r",
				"    upper(trim(estado)) == 'ACTV' ||\r",
				"    upper(trim(estado)) == 'A' ||\r",
				"    upper(trim(estado)) == 'EN ACTIVIDAD',\r",
				"\r",
				"    'ACTIVO',\r",
				"\r",
				"    iif(\r",
				"        upper(trim(estado)) == 'R' ||\r",
				"        upper(trim(estado)) == 'RSV' ||\r",
				"        upper(trim(estado)) == 'RESERVA',\r",
				"\r",
				"        'RESERVA',\r",
				"\r",
				"        iif(\r",
				"            upper(trim(estado)) == 'BAJA' ||\r",
				"            upper(trim(estado)) == 'DADO DE BAJA',\r",
				"\r",
				"            'BAJA',\r",
				"\r",
				"            'SIN DATO'\r",
				"        )\r",
				"    )\r",
				"),",
				"          ci = replace(\r",
				"    replace(\r",
				"        replace(\r",
				"            replace(\r",
				"                upper(trim(ci)),\r",
				"                'C.I.',\r",
				"                ''\r",
				"            ),\r",
				"            'CI',\r",
				"            ''\r",
				"        ),\r",
				"        '.',\r",
				"        ''\r",
				"    ),\r",
				"    '-',\r",
				"    ''\r",
				"),",
				"          salario_mensual = toDecimal(\r",
				"    replace(\r",
				"        replace(\r",
				"            replace(\r",
				"                upper(trim(salario_mensual)),\r",
				"                'BS.',\r",
				"                ''\r",
				"            ),\r",
				"            'BS',\r",
				"            ''\r",
				"        ),\r",
				"        ',',\r",
				"        ''\r",
				"    )\r",
				"),",
				"          fecha_nacimiento = iif(\r",
				"    isDate(fecha_nacimiento, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_nacimiento, 'yyyy-MM-dd'),\r",
				"\r",
				"    iif(\r",
				"        isDate(fecha_nacimiento, 'MM-dd-yyyy'),\r",
				"        toDate(fecha_nacimiento, 'MM-dd-yyyy'),\r",
				"\r",
				"        iif(\r",
				"            isDate(fecha_nacimiento, 'dd/MM/yyyy'),\r",
				"            toDate(fecha_nacimiento, 'dd/MM/yyyy'),\r",
				"\r",
				"            iif(\r",
				"                isDate(fecha_nacimiento, 'yyyy/MM/dd'),\r",
				"                toDate(fecha_nacimiento, 'yyyy/MM/dd'),\r",
				"\r",
				"                iif(\r",
				"                    isDate(fecha_nacimiento, 'dd-MMM-yyyy'),\r",
				"                    toDate(fecha_nacimiento, 'dd-MMM-yyyy'),\r",
				"\r",
				"                    iif(\r",
				"                        isDate(fecha_nacimiento, 'MMMM dd, yyyy'),\r",
				"                        toDate(fecha_nacimiento, 'MMMM dd, yyyy'),\r",
				"\r",
				"                        toDate('1900-01-01')\r",
				"                    )\r",
				"                )\r",
				"            )\r",
				"        )\r",
				"    )\r",
				"),",
				"          fecha_ingreso = iif(\r",
				"    isDate(fecha_ingreso, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_ingreso, 'yyyy-MM-dd'),\r",
				"\r",
				"    iif(\r",
				"        isDate(fecha_ingreso, 'MM-dd-yyyy'),\r",
				"        toDate(fecha_ingreso, 'MM-dd-yyyy'),\r",
				"\r",
				"        iif(\r",
				"            isDate(fecha_ingreso, 'dd/MM/yyyy'),\r",
				"            toDate(fecha_ingreso, 'dd/MM/yyyy'),\r",
				"\r",
				"            iif(\r",
				"                isDate(fecha_ingreso, 'yyyy/MM/dd'),\r",
				"                toDate(fecha_ingreso, 'yyyy/MM/dd'),\r",
				"\r",
				"                iif(\r",
				"                    isDate(fecha_ingreso, 'dd-MMM-yyyy'),\r",
				"                    toDate(fecha_ingreso, 'dd-MMM-yyyy'),\r",
				"\r",
				"                    iif(\r",
				"                        isDate(fecha_ingreso, 'MMMM dd, yyyy'),\r",
				"                        toDate(fecha_ingreso, 'MMMM dd, yyyy'),\r",
				"\r",
				"                        toDate('1900-01-01')\r",
				"                    )\r",
				"                )\r",
				"            )\r",
				"        )\r",
				"    )\r",
				")\r",
				") ~> derivedColumn1"
			]
		}
	}
}