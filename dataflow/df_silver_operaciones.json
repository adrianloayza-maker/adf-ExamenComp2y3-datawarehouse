{
	"name": "df_silver_operaciones",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_tbl_operaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as string,",
				"          id_tipo as string,",
				"          id_unidad_resp as string,",
				"          id_zona as string,",
				"          nombre_operacion as string,",
				"          fecha_inicio as string,",
				"          fecha_fin as string,",
				"          efectivos_desplegados as string,",
				"          vehiculos_utilizados as string,",
				"          duracion_dias as string,",
				"          costo_operacion as string,",
				"          resultado as string,",
				"          detenidos as string,",
				"          area_km2 as string,",
				"          incidentes as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(efectivos_desplegados = iif(\r",
				"    lower(trim(efectivos_desplegados)) == 'trescientos',\r",
				"    300,\r",
				"    iif(\r",
				"        lower(trim(efectivos_desplegados)) == 'doscientos',\r",
				"        200,\r",
				"        toInteger(regexReplace(efectivos_desplegados,'[^0-9]',''))\r",
				"    )\r",
				"),",
				"          vehiculos_utilizados = iif(\r",
				"    lower(trim(vehiculos_utilizados)) == 'veinte',\r",
				"    20,\r",
				"    toInteger(regexReplace(vehiculos_utilizados,'[^0-9]',''))\r",
				"),",
				"          duracion_dias = toInteger(\r",
				"    regexReplace(duracion_dias,'[^0-9]','')\r",
				"),",
				"          costo_operacion = toInteger(\r",
				"    regexReplace(duracion_dias,'[^0-9]','')\r",
				"),",
				"          resultado = upper(trim(resultado)),",
				"          detenidos = iif(\r",
				"    lower(trim(detenidos)) == 'ninguno',\r",
				"    0,\r",
				"    iif(\r",
				"        lower(trim(detenidos)) == 'sin detenidos',\r",
				"        0,\r",
				"        iif(\r",
				"            lower(trim(detenidos)) == 'cero',\r",
				"            0,\r",
				"            toInteger(regexReplace(detenidos,'[^0-9]',''))\r",
				"        )\r",
				"    )\r",
				"),",
				"          area_km2 = toInteger(\r",
				"    regexReplace(area_km2,'[^0-9]','')\r",
				"),",
				"          incidentes = iif(\r",
				"    lower(trim(incidentes)) == 'uno',\r",
				"    1,\r",
				"    toInteger(regexReplace(incidentes,'[^0-9]',''))\r",
				"),",
				"          fecha_inicio_normalizada_texto = replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"upper(trim(fecha_inicio)),\r",
				"'ENERO','01'),\r",
				"'FEBRERO','02'),\r",
				"'MARZO','03'),\r",
				"'ABRIL','04'),\r",
				"'MAYO','05'),\r",
				"'JUNIO','06'),\r",
				"'JULIO','07'),\r",
				"'AGOSTO','08'),\r",
				"'SEPTIEMBRE','09'),\r",
				"'OCTUBRE','10'),\r",
				"'NOVIEMBRE','11'),\r",
				"'DICIEMBRE','12'),\r",
				"'ENE','01'),\r",
				"'FEB','02'),\r",
				"'MAR','03'),\r",
				"'ABR','04'),\r",
				"'MAY','05'),\r",
				"'JUN','06'),\r",
				"'JUL','07'),\r",
				"'AGO','08'),\r",
				"'SEP','09'),\r",
				"'OCT','10'),\r",
				"'NOV','11'),\r",
				"'DIC','12'),",
				"          fecha_fin_normalizada_texto = replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"replace(\r",
				"upper(trim(fecha_fin)),\r",
				"'ENERO','01'),\r",
				"'FEBRERO','02'),\r",
				"'MARZO','03'),\r",
				"'ABRIL','04'),\r",
				"'MAYO','05'),\r",
				"'JUNIO','06'),\r",
				"'JULIO','07'),\r",
				"'AGOSTO','08'),\r",
				"'SEPTIEMBRE','09'),\r",
				"'OCTUBRE','10'),\r",
				"'NOVIEMBRE','11'),\r",
				"'DICIEMBRE','12'),\r",
				"'ENE','01'),\r",
				"'FEB','02'),\r",
				"'MAR','03'),\r",
				"'ABR','04'),\r",
				"'MAY','05'),\r",
				"'JUN','06'),\r",
				"'JUL','07'),\r",
				"'AGO','08'),\r",
				"'SEP','09'),\r",
				"'OCT','10'),\r",
				"'NOV','11'),\r",
				"'DIC','12')) ~> derivedColumn1",
				"derivedColumn1 derive(fecha_inicio_limpia = coalesce(\r",
				"    toDate(fecha_inicio_normalizada_texto,'yyyy-MM-dd'),\r",
				"    toDate(fecha_inicio_normalizada_texto,'yyyy/MM/dd'),\r",
				"    toDate(fecha_inicio_normalizada_texto,'yyyyMMdd'),\r",
				"    toDate(fecha_inicio_normalizada_texto,'dd/MM/yyyy'),\r",
				"    toDate(fecha_inicio_normalizada_texto,'MM-dd-yyyy'),\r",
				"    toDate(fecha_inicio_normalizada_texto,'dd-MM-yyyy')\r",
				"),",
				"          fecha_fin_limpia = coalesce(\r",
				"    toDate(fecha_fin_normalizada_texto,'yyyy-MM-dd'),\r",
				"    toDate(fecha_fin_normalizada_texto,'yyyy/MM/dd'),\r",
				"    toDate(fecha_fin_normalizada_texto,'yyyyMMdd'),\r",
				"    toDate(fecha_fin_normalizada_texto,'dd/MM/yyyy'),\r",
				"    toDate(fecha_fin_normalizada_texto,'MM-dd-yyyy'),\r",
				"    toDate(fecha_fin_normalizada_texto,'dd-MM-yyyy')\r",
				")) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_operacion as string,",
				"          id_tipo as string,",
				"          id_unidad_resp as string,",
				"          id_zona as string,",
				"          nombre_operacion as string,",
				"          fecha_inicio as string,",
				"          fecha_fin as string,",
				"          efectivos_desplegados as string,",
				"          vehiculos_utilizados as string,",
				"          duracion_dias as string,",
				"          costo_operacion as string,",
				"          resultado as string,",
				"          detenidos as string,",
				"          area_km2 as string,",
				"          incidentes as string,",
				"          observaciones as string",
				"     ),",
				"     partitionFileNames:['tbl_operaciones.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}