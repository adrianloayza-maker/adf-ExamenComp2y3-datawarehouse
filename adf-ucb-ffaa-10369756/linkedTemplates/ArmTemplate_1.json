		{
			"name": "[concat(parameters('factoryName'), '/df_silver_efectivos')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_bronze_tbl_efectivos",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_silver_efectivos",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          id_efectivo as string,",
						"          id_especialidad as string,",
						"          id_unidad_actual as string,",
						"          id_rango_actual as string,",
						"          nombre as string,",
						"          ci as string,",
						"          fecha_nacimiento as string,",
						"          genero as string,",
						"          departamento_origen as string,",
						"          fecha_ingreso as string,",
						"          estado as string,",
						"          salario_mensual as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 derive(genero = case(\r",
						"    in(['M','H','MASC.','MASCULINO','HOMBRE'], upper(trim(genero))), 'MASCULINO',\r",
						"    in(['F','FEM','FEM.','FEMENINO','MUJER'], upper(trim(genero))), 'FEMENINO',\r",
						"    'SIN DATO'\r",
						"),",
						"          departamento_origen = case(\r",
						"    in(['LP','L.P.','LAPAZ','LA PAZ'], upper(trim(departamento_origen))), 'LA PAZ',\r",
						"    in(['CBBA','CBBA.','COCHABAMBA'], upper(trim(departamento_origen))), 'COCHABAMBA',\r",
						"    in(['SC','SCZ','STA CRUZ','SANTA CRUZ'], upper(trim(departamento_origen))), 'SANTA CRUZ',\r",
						"    in(['OR','ORURO'], upper(trim(departamento_origen))), 'ORURO',\r",
						"    in(['PT','POTOSI'], upper(trim(departamento_origen))), 'POTOSI',\r",
						"    in(['TJ','TARIJA'], upper(trim(departamento_origen))), 'TARIJA',\r",
						"    in(['BN','BENI'], upper(trim(departamento_origen))), 'BENI',\r",
						"    in(['PD','PANDO'], upper(trim(departamento_origen))), 'PANDO',\r",
						"    in(['CH','CHUQUISACA'], upper(trim(departamento_origen))), 'CHUQUISACA',\r",
						"    upper(trim(departamento_origen))\r",
						"),",
						"          estado = case(\r",
						"    in(['ACTIVO','ACT','ACT.','ACTV','A','EN ACTIVIDAD'], upper(trim(estado))), 'ACTIVO',\r",
						"    in(['R','RSV','RESERVA','EN RESERVA'], upper(trim(estado))), 'RESERVA',\r",
						"    in(['BAJA','B','DADO DE BAJA'], upper(trim(estado))), 'BAJA',\r",
						"    'SIN DATO'\r",
						"),",
						"          ci = regexReplace(\r",
						"    toString(ci),\r",
						"    '[^0-9]',\r",
						"    ''\r",
						"),",
						"          salario_mensual = toDecimal(\r",
						"    regexReplace(\r",
						"        toString(salario_mensual),\r",
						"        '[^0-9.]',\r",
						"        ''\r",
						"    )\r",
						"),",
						"          fecha_nacimiento = coalesce(\r",
						"    toDate(fecha_nacimiento,'yyyy-MM-dd'),\r",
						"    toDate(fecha_nacimiento,'dd/MM/yyyy'),\r",
						"    toDate(fecha_nacimiento,'MM-dd-yyyy'),\r",
						"    toDate(fecha_nacimiento,'yyyy/MM/dd'),\r",
						"    toDate(fecha_nacimiento,'dd-MM-yyyy')\r",
						"),",
						"          fecha_ingreso = coalesce(\r",
						"    toDate(fecha_ingreso,'yyyy-MM-dd'),\r",
						"    toDate(fecha_ingreso,'dd/MM/yyyy'),\r",
						"    toDate(fecha_ingreso,'MM-dd-yyyy'),\r",
						"    toDate(fecha_ingreso,'yyyy/MM/dd'),\r",
						"    toDate(fecha_ingreso,'dd-MM-yyyy')\r",
						"),",
						"          nombre = initCap(\r",
						"    regexReplace(\r",
						"        replace(\r",
						"            replace(\r",
						"                replace(\r",
						"                    replace(\r",
						"                        replace(\r",
						"                            replace(\r",
						"                                replace(\r",
						"                                    replace(\r",
						"                                        trim(nombre),\r",
						"                                        '\\\\t',\r",
						"                                        ' '\r",
						"                                    ),\r",
						"                                    'Ã¡',\r",
						"                                    'á'\r",
						"                                ),\r",
						"                                'Ã©',\r",
						"                                'é'\r",
						"                            ),\r",
						"                            'Ã­',\r",
						"                            'í'\r",
						"                        ),\r",
						"                        'Ã³',\r",
						"                        'ó'\r",
						"                    ),\r",
						"                    'Ãº',\r",
						"                    'ú'\r",
						"                ),\r",
						"                'Ã±',\r",
						"                'ñ'\r",
						"            ),\r",
						"            '#',\r",
						"            ' '\r",
						"        ),\r",
						"        '\\\\s+',\r",
						"        ' '\r",
						"    )\r",
						")) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          id_efectivo as string,",
						"          id_especialidad as string,",
						"          id_unidad_actual as string,",
						"          id_rango_actual as string,",
						"          nombre as string,",
						"          ci as string,",
						"          fecha_nacimiento as string,",
						"          genero as string,",
						"          departamento_origen as string,",
						"          fecha_ingreso as string,",
						"          estado as string,",
						"          salario_mensual as string",
						"     ),",
						"     partitionFileNames:['tbl_efectivos.csv'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     mapColumn(",
						"          id_efectivo,",
						"          id_especialidad,",
						"          id_unidad_actual,",
						"          id_rango_actual,",
						"          nombre,",
						"          ci,",
						"          fecha_nacimiento,",
						"          genero,",
						"          departamento_origen,",
						"          fecha_ingreso,",
						"          estado,",
						"          salario_mensual",
						"     ),",
						"     partitionBy('hash', 1)) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
